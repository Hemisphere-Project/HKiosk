# HKiosk
# --url <url>             URL to load
# --rotate <deg>          Rotate screen (0, 90, 180, 270)
# --reflect <mode>        Reflect screen (n, x, y, xy)
# --resolution <WxH>      Force resolution (e.g. 1920x1080), default auto
# --nocursor              Hide cursor
# --devtools              Show devtools (disable fullscreen)
# --extra "<flags>"       Extra chromium flags

--url https://hemisphere-project.com --nocursor
